{
    "description": "Popular open source web browser. Cross-platform and available in many languages.",
    "homepage": "https://www.mozilla.org/ja/firefox/new/",
    "version": "67.0.1",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://download.mozilla.org/?product=firefox-67.0.1-SSL&os=win64&lang=ja#/firefox.7z",
            "hash": "99f4516e818a282e0052f77f35e37923e1e318fafbb2bf4a7d176c29d8163d91"
        },
        "32bit": {
            "url": "https://download.mozilla.org/?product=firefox-67.0.1-SSL&os=win&lang=ja#/firefox.7z",
            "hash": "80e98a4393d32c45a9cf3db12730b4359ac616d7e2c9f7a1c00c30d5b888d6dc"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Mozilla Firefox"
        ]
    ],
    "checkver": {
        "url": "https://www.mozilla.org/ja/firefox/all/",
        "re": "data-latest-firefox=\"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win64&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win64/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            },
            "32bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win32/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            }
        }
    }
}
