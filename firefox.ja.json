    "architecture": {
        "64bit": {
            "url": "https://download.mozilla.org/?product=firefox-69.0.1-SSL&os=win64&lang=ja#/firefox.7z",
            "hash": "29ffdef2b4da4c0e405f9ac12d4114f7311330daf501c9d80abe1d37d1910daa"
        },
        "32bit": {
            "url": "https://download.mozilla.org/?product=firefox-69.0.1-SSL&os=win&lang=ja#/firefox.7z",
            "hash": "2e9d175e4e6b0995d3de46d377d04273c54de2386661e5c9df80c72703408e00"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Mozilla Firefox"
        ]
    ],
    "checkver": {
        "url": "https://www.mozilla.org/ja/firefox/all/",
        "re": "data-latest-firefox=\"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win64&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win64/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            },
            "32bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win32/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            }
        }
    }
}
