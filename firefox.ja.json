    "architecture": {
        "64bit": {
            "url": "https://download.mozilla.org/?product=firefox-66.0.3-SSL&os=win64&lang=ja#/firefox.7z",
            "hash": "085bbb6789bcc60c16a6ea1a7ee3cd22425c623179944f96996c5be11e48fd9e"
        },
        "32bit": {
            "url": "https://download.mozilla.org/?product=firefox-66.0.3-SSL&os=win&lang=ja#/firefox.7z",
            "hash": "c205124eaa157b05163001429be4500eeba2e6b98a958595a8c9040627b9766e"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Mozilla Firefox"
        ]
    ],
    "checkver": {
        "url": "https://www.mozilla.org/ja/firefox/all/",
        "re": "data-latest-firefox=\"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win64&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win64/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            },
            "32bit": {
                "url": "https://download.mozilla.org/?product=firefox-$version-SSL&os=win&lang=ja#/firefox.7z",
                "hash": {
                    "find": "([a-fA-F0-9]{64})\\s+(?:win32/ja/Firefox Setup ([\\d.]+).exe)",
                    "url": "https://download-installer.cdn.mozilla.net/pub/firefox/releases/$version/SHA256SUMS"
                }
            }
        }
    }
}
