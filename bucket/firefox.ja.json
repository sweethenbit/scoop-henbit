{
    "version": "79.0",
    "description": "Popular open source web browser.",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/79.0/win64/ja/Firefox%20Setup%2079.0.exe#/dl.7z",
            "hash": "14f15a79e845a7db4ceb55b5e53e15dacb4af2537c0b4694dbd126aea71619b5"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/79.0/win32/ja/Firefox%20Setup%2079.0.exe#/dl.7z",
            "hash": "cb975356035bdd3474e480510ecc851cd7e6364ca9826fa1f86c65be8fb2ae12"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ]
    ],
    "checkver": {
        "url": "https://www.mozilla.org/ja/firefox/notes/",
        "regex": "<div class=\"c-release-version\">([\\d.]+)</div>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/ja/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/ja/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/ja/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/ja/$basename"
                }
            }
        }
    }
}
